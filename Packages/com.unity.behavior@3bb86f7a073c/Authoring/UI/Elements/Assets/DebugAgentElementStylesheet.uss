Toggle {
    flex-direction: row-reverse;
    justify-content: space-between;
    height: 30px;
    padding-left: 12px;
    padding-right: 12px;
}

HelpText {
    margin-top: 8px;
    padding-left: 12px;
    padding-right: 12px;
}

#ReturnButton {
    display: none;
}

Toggle LocalizedTextElement {
    flex-shrink: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-right: 4px;
}

Divider {
    padding: 2px 12px;
}

.appui-divider__content {
    background-color: var(--behavior-ui-edge-color);
}